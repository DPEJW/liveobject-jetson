# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Runtime artifacts
snapshots/
*.log
hailort*.log

# Camera credentials (local only — never commit real creds)
.camera.env

# Model weights / engines (large; .engine is specific to this TensorRT/GPU,
