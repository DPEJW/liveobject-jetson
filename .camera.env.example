# Camera configuration for liveobject.
#
# Copy this file to `.camera.env` (which is gitignored) and fill in real values.
# config.py loads `.camera.env` automatically at startup; real environment
# variables still override it, e.g.  CAMERA_SOURCE=basler python3 app.py
#
# ---------------------------------------------------------------------------
# Capture backend:  rtsp  -> IP camera over RTSP (Reolink PoE). On Jetson this
#                           used GStreamer NVDEC; on other GPUs (e.g. GB10) it
#                           auto-falls back to OpenCV's FFmpeg decode.
#                   basler-> Basler GigE Vision via pypylon (original path)
# NOTE: the .env loader does NOT strip inline "# comments" after a value (a '#'
# can be part of a password), so keep comments on their own lines like this.
CAMERA_SOURCE=rtsp

# RTSP / IP camera settings (used when CAMERA_SOURCE=rtsp).
# Credentials are URL-encoded automatically, so '#', '@', ':' etc. are fine.
RTSP_HOST=192.168.1.104
RTSP_PORT=554
RTSP_USER=admin
RTSP_PASS=changeme
# RTSP_STREAM: main (2560x1920 @ 25fps) or sub (640x480 @ 10fps)
RTSP_STREAM=main

# Optional: full URL override (wins over the RTSP_* parts above).
# RTSP_URL=rtsp://admin:pass@192.168.1.104:554/h264Preview_01_main
